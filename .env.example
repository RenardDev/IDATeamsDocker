# Copy this file to ".env" and set strong values before running the services.
# Do not commit your real ".env" file.

# Public service endpoints.
LICENSE_HOST=reversing.example.com
LICENSE_PORT=65434
VAULT_HOST=reversing.example.com
VAULT_PORT=65433
LUMINA_HOST=reversing.example.com
LUMINA_PORT=443

# HexVault configures this fixed admin account only during fresh schema creation.
VAULT_PASSWORD=

MYSQL_DATABASE=lumina
MYSQL_USER=lumina
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Lumina uses its regular schema unless Vault integration is explicitly enabled.
VAULT_ENABLED=false

# Optional remote backup. SYNC_HOST_ID remains service-specific in each compose file.
SYNC_ENABLED=false
SYNC_READ_ONLY=false
SYNC_METHOD=commits
SYNC_INTERVAL_SECONDS=3600
SYNC_NETWORK_TIMEOUT_SECONDS=300
SYNC_LOCK_TIMEOUT_SECONDS=30
SYNC_FINAL_TIMEOUT_SECONDS=300
SYNC_RELEASE_KEEP=3
SYNC_CHUNK_SIZE_MB=49
SYNC_FORCE_RESTORE=false
SYNC_MAX_RESTORE_MB=10240
SYNC_MAX_EXTRACT_MB=20480

# Required to publish or restore snapshots. Use a unique random value of at least 20 characters.
SYNC_ENCRYPTION_PASSPHRASE=

# Set these only when GitHub sync is enabled.
GH_REMOTE=
SYNC_AUTH_TOKEN=
